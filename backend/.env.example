# ── Omnibus backend environment variables ────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# TCP port the backend listens on (default: value from config/app.json → 8686)
# PORT=8686

# Absolute path to the directory that stores JSON config files.
# Useful for Docker volume mounts (e.g. -v /host/config:/data/config).
# Default: <cwd>/config
# CONFIG_DIR=/data/config
